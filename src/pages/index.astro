---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✈️</text></svg>" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Cuenta Regresiva ✈️</title>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&display=swap');

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html, body {
				height: 100%;
				font-family: 'Space Grotesk', sans-serif;
				overflow: hidden;
			}

			body {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				background: #000 url('/PHOTO-2025-08-16-09-34-54.jpg') center/cover no-repeat fixed;
				color: #fff;
				min-height: 100dvh;
				position: relative;
			}

			body::after {
				content: '';
				position: absolute;
				inset: 0;
				background: rgba(0, 0, 0, 0.7);
			}

			.container {
				text-align: center;
				z-index: 1;
				padding: 2rem;
			}

			.date {
				font-size: clamp(0.9rem, 2.5vw, 1.1rem);
				color: rgba(255, 255, 255, 0.5);
				margin-bottom: 3rem;
				font-weight: 400;
			}

			.countdown {
				display: flex;
				gap: clamp(0.8rem, 3vw, 2rem);
				justify-content: center;
				flex-wrap: wrap;
			}

			.unit {
				display: flex;
				flex-direction: column;
				align-items: center;
				min-width: clamp(80px, 15vw, 130px);
			}

			.number {
				font-size: clamp(3rem, 10vw, 5.5rem);
				font-weight: 700;
				line-height: 1;
				color: #fff;
				font-variant-numeric: tabular-nums;
				min-width: 2ch;
				display: inline-block;
				text-align: center;
			}

			.label {
				font-size: clamp(0.7rem, 2vw, 0.9rem);
				color: rgba(255, 255, 255, 0.4);
				text-transform: uppercase;
				letter-spacing: 0.15em;
				margin-top: 0.5rem;
			}

			.separator {
				font-size: clamp(2.5rem, 8vw, 4.5rem);
				font-weight: 700;
				color: rgba(255, 255, 255, 0.15);
				align-self: flex-start;
				line-height: 1;
			}

			.arrived {
				font-size: clamp(2rem, 6vw, 3.5rem);
				font-weight: 700;
				color: #fff;
			}

			@media (max-width: 600px) {
				.countdown {
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 1.5rem 1rem;
				}

				.separator {
					display: none;
				}

				.unit {
					min-width: unset;
				}
			}
		</style>
	</head>
	<body>
		<div class="container">
<div class="countdown" id="countdown">
				<div class="unit">
					<span class="number" id="days">--</span>
					<span class="label">Días</span>
				</div>
				<span class="separator">:</span>
				<div class="unit">
					<span class="number" id="hours">--</span>
					<span class="label">Horas</span>
				</div>
				<span class="separator">:</span>
				<div class="unit">
					<span class="number" id="minutes">--</span>
					<span class="label">Minutos</span>
				</div>
				<span class="separator">:</span>
				<div class="unit">
					<span class="number" id="seconds">--</span>
					<span class="label">Segundos</span>
				</div>
			</div>
		</div>

		<script>
			// 12 de septiembre 2026, 21:15 horario Argentina (UTC-3)
			const TARGET = new Date('2026-09-12T21:15:00-03:00').getTime();

			function pad(n) {
				return String(n).padStart(2, '0');
			}

			function update() {
				const now = Date.now();
				const diff = TARGET - now;

				if (diff <= 0) {
					document.getElementById('countdown').innerHTML =
						'<span class="arrived">🎉 ¡Nos vamos! 🎉</span>';
					return;
				}

				const days = Math.floor(diff / (1000 * 60 * 60 * 24));
				const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
				const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
				const seconds = Math.floor((diff % (1000 * 60)) / 1000);

				document.getElementById('days').textContent = days;
				document.getElementById('hours').textContent = pad(hours);
				document.getElementById('minutes').textContent = pad(minutes);
				document.getElementById('seconds').textContent = pad(seconds);
			}

			update();
			setInterval(update, 1000);
		</script>
	</body>
</html>
